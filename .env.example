# MongoDB (usado por docker-compose.yml)
MONGO_ROOT_USER=admin
MONGO_ROOT_PASSWORD=changeme
MONGO_EXPRESS_USER=admin
MONGO_EXPRESS_PASSWORD=changeme

# Connection string completo para usar en n8n (credencial MongoDB)
# mongodb://admin:changeme@localhost:27017/chatbot_atencion_cliente?authSource=admin
MONGODB_URI=mongodb://admin:changeme@localhost:27017/chatbot_atencion_cliente?authSource=admin

# Telegram
# Token del bot obtenido de @BotFather
TELEGRAM_BOT_TOKEN=
# chat_id del negocio/admin que recibe las notificaciones cuando el bot no sabe responder
ADMIN_CHAT_ID=
