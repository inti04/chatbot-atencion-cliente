      },
      "id": "d2fd855a-eff5-4ffb-9a91-2f50c31cd86d",
      "name": "Recibir mensaje de Telegram",
      "type": "n8n-nodes-base.telegramTrigger",
      "typeVersion": 1.3,
      "position": [240, 304],
      "webhookId": "e7c0bdc5-4d05-4781-8e19-defd825dd0c6"
    },
    {
      "parameters": {
        "mode": "runOnceForEachItem",
        "jsCode": "const message = $json.message || {};\nconst text = message.text || '';\nconst chatId = message.chat ? message.chat.id : null;\nconst username = (message.from && (message.from.username || message.from.first_name)) || 'desconocido';\n\nreturn {\n  json: {\n    chat_id: chatId,\n    username,\n    message: text,\n  }\n};"
      },
      "id": "b4eab4fa-d8d7-4d38-9a52-33b950e2aae1",
      "name": "Normalizar mensaje",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [464, 304]
    },
    {
      "parameters": {
        "promptType": "define",
        "text": "={{ $json.message }}",
        "hasOutputParser": true,
        "options": {
          "systemMessage": "Eres el asistente virtual de una clinica dental y respondes a pacientes por Telegram. Antes de responder cualquier pregunta sobre horarios, precios, servicios o disponibilidad, SIEMPRE usa la herramienta \"Buscar informacion de la clinica\" para consultar la informacion real del negocio. Responde de forma calida, profesional y natural, como lo haria una recepcionista. Nunca inventes precios, horarios ni servicios que no aparezcan en la herramienta. Debes devolver un JSON con dos campos: \"response\" (el mensaje que se le enviara al paciente) y \"resolved\" (true si encontraste informacion suficiente en la herramienta para responder con confianza, false si no tienes informacion suficiente y un humano deberia hacer seguimiento). Si no tienes informacion suficiente, en \"response\" igual da la mejor respuesta posible y avisa amablemente que un miembro del equipo se pondra en contacto."
        }
      },
      "id": "a6d0ce95-87c2-4e91-b5cc-dd1159441489",
      "name": "Agente Clinica Dental",
      "type": "@n8n/n8n-nodes-langchain.agent",
      "typeVersion": 3.1,
      "position": [688, 304]
    },
    {
      "parameters": {
        "modelName": "models/gemini-3.1-flash-lite",
        "options": {}
      },
      "id": "3eb2e9ef-2642-46cf-8d9b-6a3f3ee57971",
      "name": "Google Gemini Model",
      "type": "@n8n/n8n-nodes-langchain.lmChatGoogleGemini",
      "typeVersion": 1.1,
      "position": [640, 512]
    },
    {
      "parameters": {
        "sessionIdType": "customKey",
