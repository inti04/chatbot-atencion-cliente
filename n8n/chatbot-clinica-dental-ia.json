      "id": "08ee701c-ee4e-4373-9c31-f1fd4cb74dff",
      "name": "Buscar informacion de la clinica",
      "type": "n8n-nodes-base.mongoDbTool",
      "typeVersion": 1.3,
      "position": [800, 512],
      "notes": "Devuelve las preguntas frecuentes activas (horarios, precios, servicios, disponibilidad) de la clinica dental. Usar antes de responder cualquier pregunta sobre el negocio."
    },
    {
      "parameters": {
        "jsonSchemaExample": "{ \"response\": \"Atendemos ortodoncia de lunes a viernes de 9am a 6pm.\", \"resolved\": true }"
      },
      "id": "e6731828-a953-40ea-b7a4-50cd489eb398",
      "name": "Formato de respuesta",
      "type": "@n8n/n8n-nodes-langchain.outputParserStructured",
      "typeVersion": 1.3,
      "position": [1120, 512]
    },
    {
      "parameters": {
        "jsCode": "const src = $('Normalizar mensaje').first().json;\nconst agentOut = ($input.first().json && $input.first().json.output) || {};\n\nfunction escapeHtml(str) {\n  return String(str || '')\n    .replace(/&/g, '&amp;')\n    .replace(/</g, '&lt;')\n    .replace(/>/g, '&gt;');\n}\n\nconst resolved = agentOut.resolved === true;\nconst responseText = escapeHtml(agentOut.response || 'Gracias por tu mensaje. Un miembro del equipo te contactara pronto.');\nconst timestamp = new Date().toISOString();\n\nreturn [{\n  json: {\n    chat_id: src.chat_id,\n    username: escapeHtml(src.username),\n    message: escapeHtml(src.message),\n    resolved,\n    response: responseText,\n    status: resolved ? 'answered' : 'unanswered',\n    timestamp,\n  }\n}];"
      },
      "id": "ab09185e-db4a-47f0-8fc5-9ddec77c1b20",
      "name": "Preparar respuesta",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [1344, 304]
    },
    {
